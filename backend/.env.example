# ───── Database ─────
DATABASE_URL=postgresql+asyncpg://importer:importer@localhost:5432/importer

# ───── Session / Crypto ─────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-to-a-fernet-key

# ───── Basalam OAuth ─────
BASALAM_CLIENT_ID=
BASALAM_CLIENT_SECRET=
BASALAM_REDIRECT_URI=http://localhost:8000/api/v1/auth/basalam/callback
BASALAM_AUTHORIZE_URL=https://basalam.com/accounts/oauth/authorize
BASALAM_TOKEN_URL=https://basalam.com/accounts/oauth/token
BASALAM_OPENAPI_BASE=https://openapi.basalam.com
BASALAM_SCOPES=vendor.product.read vendor.product.write customer.profile.read

# ───── Optional Basalam Bridge (TS BasalamService.connectSite contract) ─────
# When set, OAuth code is POSTed to ${BASALAM_BRIDGE_URL}/basalam/connect
# with header x-api-key: ${BASALAM_BRIDGE_API_KEY}
BASALAM_BRIDGE_URL=
BASALAM_BRIDGE_API_KEY=

# ───── Basalam product config ─────
BASALAM_PRODUCT_STATUS=2976

# ───── OpenRouter (AI) ─────
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# ───── Ledger ─────
COST_PER_PRODUCT=1
SIGNUP_GIFT_AMOUNT=0

# ───── App ─────
APP_ORIGIN=http://localhost:3000
SESSION_COOKIE_NAME=pi_session
SESSION_TTL_DAYS=7
COOKIE_SECURE=false
